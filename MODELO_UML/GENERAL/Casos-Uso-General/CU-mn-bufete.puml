@startuml

left to right direction

skinparam backgroundColor white
skinparam packageStyle rectangle
skinparam shadowing false

skinparam usecase {
BackgroundColor #E8F5E9
BorderColor #2E7D32
}

skinparam actor {
BorderColor #1B5E20
}

actor Cliente
actor "Abogado Principal" as Abogado
actor Administrador

rectangle "SISTEMA IURIS - MINI BUFETE DE ABOGADOS" {


package "Autenticación y Perfil" {

    usecase "Registrarse" as UC1
    usecase "Iniciar Sesión" as UC2
    usecase "Recuperar Contraseña" as UC3
    usecase "Gestionar Perfil" as UC4

}

package "Gestión de Casos" {

    usecase "Solicitar Consulta Legal" as UC5
    usecase "Crear Expediente" as UC6
    usecase "Actualizar Estado del Caso" as UC7
    usecase "Ver Estado del Caso" as UC8
    usecase "Ver Historial de Casos" as UC9
    usecase "Registrar Actuación Procesal" as UC10
    usecase "Registrar Resolución" as UC11
    usecase "Cerrar Caso" as UC12

}

package "Gestión de Documentos" {

    usecase "Subir Documento" as UC13
    usecase "Descargar Documento" as UC14
    usecase "Auditar Accesos a Documentos" as UC15

}

package "Gestión de Citas y Audiencias" {

    usecase "Agendar Cita" as UC16
    usecase "Reprogramar Cita" as UC17
    usecase "Cancelar Cita" as UC18
    usecase "Gestionar Audiencias" as UC19

}

package "Gestión de Pagos" {

    usecase "Realizar Pago" as UC20
    usecase "Ver Historial de Pagos" as UC21

}

package "Comunicación" {

    usecase "Chat Cliente-Abogado" as UC22
    usecase "Solicitar Videollamada" as UC23
    usecase "Recibir Notificaciones" as UC24

}

package "Administración del Sistema" {

    usecase "Gestionar Usuarios" as UC25
    usecase "Gestionar Clientes" as UC26
    usecase "Gestionar Abogados" as UC27
    usecase "Gestionar Roles" as UC28
    usecase "Gestionar Permisos" as UC29
    usecase "Gestionar Especialidades Legales" as UC30
    usecase "Gestionar Sedes" as UC31
    usecase "Configurar Sistema" as UC32
    usecase "Generar Estadísticas" as UC33
    usecase "Generar Reportes Administrativos" as UC34

}

}

