@startuml

title Diagrama de Secuencia — Secretaria / Asistente Administrativo\nCU-SC-08 Atención Inicial + CU-SC-02 Registrar Nuevo Cliente

autonumber

actor "Secretaria" as Sec
participant "App Web" as App
participant "API Gateway" as GW
participant "UsuarioController" as Ctrl
participant "UsuarioService" as Svc
participant "SedeValidator" as Sede
participant "UsuarioRepository" as Repo
database "DB Usuarios" as DB
participant "CasoController" as CCtrl
participant "CasoService" as CSvc

Sec -> App : Atiende al contacto\ny recopila datos iniciales
App -> GW : (registro interno de\natención, sin persistencia aún)
GW --> App : ack

Sec -> App : Registra al contacto\ncomo nuevo cliente
App -> GW : POST /users (rol=Cliente)
GW -> GW : Valida token JWT\ny rol Secretaria
GW -> Ctrl : POST /users

Ctrl -> Svc : registrarCliente(datos)
Svc -> Repo : existePorCorreo(correo)
Repo -> DB : SELECT WHERE correo = ?
DB --> Repo : resultado

alt correo ya registrado (RN-06)
    Repo --> Svc : correo duplicado
    Svc --> Ctrl : 409 Conflict
    Ctrl --> GW : 409 Conflict
    GW --> App : 409 Conflict
    App --> Sec : "El correo ya existe\nen el sistema"
else correo disponible
    Svc -> Sede : validarSede(sedeId)
    Sede --> Svc : sede activa (RN-07)
    Svc -> Repo : guardarUsuario(rol="Cliente")
    Repo -> DB : INSERT INTO usuarios (...)
    DB --> Repo : usuario creado
    Repo --> Svc : ok
    Svc --> Ctrl : cliente registrado
    Ctrl --> GW : 201 Created
    GW --> App : 201 Created
    App --> Sec : Cliente registrado exitosamente

    Sec -> App : Deriva la solicitud\na Consulta Legal (CU-05)
    App -> GW : POST /cases/solicitudes
    GW -> CCtrl : POST /cases/solicitudes
    CCtrl -> CSvc : registrarSolicitudConsulta(cliente)
    CSvc --> CCtrl : solicitud registrada
    CCtrl --> GW : 201 Created
    GW --> App : 201 Created
    App --> Sec : Solicitud derivada,\nlista para apertura de caso
end

@enduml
