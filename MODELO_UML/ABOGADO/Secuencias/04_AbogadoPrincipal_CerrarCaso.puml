@startuml

title Diagrama de Secuencia — Abogado Principal\nCU-AB-11 Registrar Resolución + CU-AB-12 Cerrar Caso

autonumber

actor "Abogado Principal" as Abg
participant "App Web" as App
participant "API Gateway" as GW
participant "CasoController" as Ctrl
participant "CasoService" as Svc
participant "EstadoCasoMachine" as Machine
participant "CasoRepository" as Repo
database "DB Casos" as DB
participant "NotificacionCasoPublisher" as Pub
participant "MS Comunicación" as Comm

Abg -> App : Redacta y registra\nla resolución final del caso
App -> GW : POST /cases/{id}/resolucion
GW -> Ctrl : POST /cases/{id}/resolucion

Ctrl -> Svc : registrarResolucion(caso, resolucion)
Svc -> Repo : guardarResolucion(resolucion)
Repo -> DB : INSERT INTO resoluciones (...)
DB --> Repo : resolución persistida
Repo --> Svc : ok
Svc --> Ctrl : resolución registrada
Ctrl --> App : 201 Created
App --> Abg : Confirma resolución registrada

Abg -> App : Solicita cerrar el caso
App -> GW : PATCH /cases/{id}/estado\n(estado = "Cerrado")
GW -> Ctrl : PATCH /cases/{id}/estado

Ctrl -> Svc : cerrarCaso(caso)
Svc -> Repo : existeResolucion(caso)
Repo -> DB : SELECT resolucion WHERE caso = ?
DB --> Repo : resultado

alt no existe resolución registrada (RN-09)
    Repo --> Svc : sin resolución
    Svc --> Ctrl : 409 Conflict -\nresolución obligatoria previa
    Ctrl --> GW : 409 Conflict
    GW --> App : 409 Conflict
    App --> Abg : "Debe registrar la resolución\nantes de cerrar el caso"
else resolución existente
    Repo --> Svc : resolución encontrada
    Svc -> Machine : transicionar(estadoActual, "Cerrado")
    Machine --> Svc : transición válida
    Svc -> Repo : actualizarEstadoCaso(caso, "Cerrado")
    Repo -> DB : UPDATE casos SET estado = "Cerrado"
    DB --> Repo : actualizado
    Repo --> Svc : ok

    Svc -> Pub : publicarEvento("CasoActualizado")
    Pub -> Comm : evento CasoActualizado
    Comm -> Comm : Notificar al cliente\nel cierre del caso
    Comm --> Pub : ack

    Svc --> Ctrl : caso cerrado
    Ctrl --> GW : 200 OK
    GW --> App : 200 OK
    App --> Abg : Caso cerrado exitosamente
end

@enduml
